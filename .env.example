# Django
SECRET_KEY=your-secret-key-here
DEBUG=True
ALLOWED_HOSTS=localhost,127.0.0.1
EXTRA_ALLOWED_HOSTS=.onrender.com

# Database
DB_NAME=recall_db
DB_USER=postgres
DB_PASSWORD=your-password
DB_HOST=localhost
DB_PORT=5432

# Redis
REDIS_URL=redis://localhost:6379/0

# AWS Bedrock
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_REGION=us-east-1

# Bot Protection
TURNSTILE_ENABLED=False
TURNSTILE_SECRET_KEY=your-cloudflare-turnstile-secret
REACT_APP_TURNSTILE_SITE_KEY=your-cloudflare-turnstile-site-key

# OAuth
GOOGLE_OAUTH_ENABLED=False
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=your-google-client-secret
MICROSOFT_CLIENT_ID=your-microsoft-client-id
MICROSOFT_CLIENT_SECRET=your-microsoft-client-secret
MICROSOFT_TENANT_ID=common

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000
CSRF_TRUSTED_ORIGINS=http://localhost:3000

# API throttles
DRF_ANON_THROTTLE_RATE=60/min
DRF_USER_THROTTLE_RATE=300/min

# Auth endpoint rate-limits (requests per window in seconds)
AUTH_LOGIN_RATE_LIMIT=5
AUTH_LOGIN_RATE_WINDOW=3600
AUTH_GOOGLE_LOGIN_RATE_LIMIT=10
AUTH_GOOGLE_LOGIN_RATE_WINDOW=3600
AUTH_REGISTER_RATE_LIMIT=5
AUTH_REGISTER_RATE_WINDOW=3600
AUTH_FORGOT_PASSWORD_RATE_LIMIT=10
AUTH_FORGOT_PASSWORD_RATE_WINDOW=3600
AUTH_WORKSPACE_SWITCH_CODE_RATE_LIMIT=20
AUTH_WORKSPACE_SWITCH_CODE_RATE_WINDOW=3600
AUTH_WORKSPACE_SWITCH_RATE_LIMIT=30
AUTH_WORKSPACE_SWITCH_RATE_WINDOW=3600
AUTH_INVITE_SEND_RATE_LIMIT=20
AUTH_INVITE_SEND_RATE_WINDOW=3600
AUTH_INVITE_RESEND_RATE_LIMIT=60
AUTH_INVITE_RESEND_RATE_WINDOW=3600

# Response security headers
SECURITY_ENABLE_CSP=True
SECURITY_CSP_REPORT_ONLY=True
SECURITY_CSP_POLICY=default-src 'self'; base-uri 'self'; frame-ancestors 'none'; object-src 'none'; img-src 'self' data: https:; style-src 'self' 'unsafe-inline' https:; font-src 'self' data: https:; connect-src 'self' https: wss:; script-src 'self' https://accounts.google.com https://apis.google.com https://www.gstatic.com; frame-src https://accounts.google.com https://challenges.cloudflare.com;
SECURITY_PERMISSIONS_POLICY=camera=(), microphone=(), geolocation=(), payment=(), usb=(), interest-cohort=()

# Error monitoring (Sentry)
SENTRY_DSN=
SENTRY_ENVIRONMENT=development
SENTRY_TRACES_SAMPLE_RATE=0.0
REACT_APP_SENTRY_DSN=
REACT_APP_SENTRY_ENVIRONMENT=development
REACT_APP_SENTRY_TRACES_SAMPLE_RATE=0
